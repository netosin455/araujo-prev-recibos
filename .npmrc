# ─────────────────────────────────────────────────────────────
# Configuração de segurança do npm — proteção contra ataques de
# "supply chain" (dependências maliciosas), como o do TanStack (2026).
# Ver docs/ e reports/security_report.md para o contexto.
# ─────────────────────────────────────────────────────────────

# 1) NÃO executar scripts de instalação (postinstall/preinstall/install)
#    das dependências. Esse é o vetor #1 desses ataques: um pacote
#    comprometido executa código na máquina no momento do `npm install`.
#    Verificado neste projeto: nenhuma dependência PRECISA desses scripts
#    (o app sobe via `node web/server.js`, não via `npm start`; o único
#    pacote com script era o `scarf`, que só faz telemetria).
ignore-scripts=true

# 2) Ao instalar um pacote novo, gravar a versão EXATA (sem ^ ou ~).
#    Evita que uma atualização automática puxe uma versão recém-
#    comprometida sem ninguém perceber. O package-lock.json continua
#    sendo a trava principal; isto reforça no momento de adicionar deps.
save-exact=true

# 3) Rodar auditoria de vulnerabilidades automaticamente nas instalações.
audit=true

# 4) Menos ruído de propaganda no terminal.
fund=false

# NOTA: o npm (diferente do pnpm) NÃO tem uma opção nativa de "idade mínima
# do pacote". Para adotar essa prática (só instalar versões com alguns dias
# de vida, dando tempo da comunidade detectar veneno), use manualmente:
#   npm install <pacote>  e confira a data da versão, ou uma ferramenta
#   como o Socket (socket.dev). Ver recomendações no security_report.md.
