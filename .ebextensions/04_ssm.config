commands:
  enable_ssm_agent:
    # Permite acesso via AWS Systems Manager (Session Manager) sem precisar de
    # chave SSH — o agente já vem instalado no Amazon Linux 2023, só não estava
    # habilitado. Usado para diagnóstico/manutenção pontual da instância.
    command: "systemctl enable --now amazon-ssm-agent"
    ignoreErrors: true
