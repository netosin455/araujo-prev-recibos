option_settings:
  aws:elasticbeanstalk:application:environment:
    # Endereço público HTTPS (CloudFront) usado nos links de assinatura remota.
    # CloudFront entrega HTTPS válido (o domínio .elasticbeanstalk.com não tem),
    # o que é exigido pelos celulares pra abrir o link. Troque aqui se mudar de domínio.
    APP_URL: https://dmd9wnmdoejv4.cloudfront.net
    # Espelho local dos documentos do Fichário (fallback quando S3 falha).
    # O diretório é criado automaticamente pelo .ebextensions/01_data_dir.config.
    MIRROR_LOCAL_DIR: /var/data/araujo-prev/documentos
