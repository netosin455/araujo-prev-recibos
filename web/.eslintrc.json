{
  "env": {
    "node": true,
    "browser": true,
    "es2022": true,
    "jest": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "script"
  },
  "extends": ["eslint:recommended"],
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "eqeqeq": ["error", "always"],
    "curly": "warn",
    "no-throw-literal": "error",
    "prefer-const": "warn",
    "no-var": "warn"
  },
  "ignorePatterns": ["node_modules/", "public/libs/"]
}
