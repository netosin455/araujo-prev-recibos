# Segurança do npm — proteção contra ataques de supply chain.
# Cópia da configuração da raiz (o npm lê o .npmrc do diretório onde roda;
# como o EB pode instalar dentro de web/, mantemos aqui também).
# Ver reports/security_report.md para o contexto completo.

# Não executar scripts de instalação de dependências (vetor #1 de ataque).
ignore-scripts=true

# Gravar versão exata ao adicionar novos pacotes.
save-exact=true

# Auditoria automática de vulnerabilidades.
audit=true

# Menos ruído.
fund=false
