{
  "name": "araujo-prev-web",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "lint": "eslint . --ext .js,.mjs --ignore-pattern node_modules --ignore-pattern public/libs",
    "format": "prettier --write \"**/*.js\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.js\" --ignore-path .gitignore",
    "test": "node --test \"../tests/*.test.js\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/client-sqs": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "compression": "1.8.1",
    "cookie-parser": "^1.4.7",
    "docx": "^8.5.0",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-cron": "4.6.0",
    "nodemailer": "9.0.3",
    "pdfkit": "^0.18.0",
    "pg": "^8.13.0",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "^10.6.0",
    "prettier": "^3.9.3",
    "supertest": "7.2.2"
  }
}
